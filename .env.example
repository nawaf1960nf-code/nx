# متغيرات بيئة نون عين - انسخ هذا الملف إلى .env.local وعبّي القيم

# Supabase (آمنة للعرض)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxx

# Supabase (سرية - لا تنشرها)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxx

# Anthropic Claude API (سري)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxx

# Pexels API (للصور المرفقة بالأسئلة) - مجاني
# سجل في https://www.pexels.com/api/
PEXELS_API_KEY=
